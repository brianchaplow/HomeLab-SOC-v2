# HomeLab SOC v2 - Environment Variables
# Copy to .env and fill in your values
# Location: /share/Container/SOC/compose/.env

# =============================================================================
# OpenSearch
# =============================================================================
# Password for OpenSearch admin user
# Minimum 8 chars, uppercase, lowercase, number, special char
OPENSEARCH_PASSWORD=YourSecurePassword123!

# =============================================================================
# Threat Intelligence - AbuseIPDB
# =============================================================================
# Get free API key at https://www.abuseipdb.com/account/api
# Free tier: 1000 checks/day
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# =============================================================================
# Cloudflare - Auto-Blocking
# =============================================================================
# API Token with Zone:Firewall:Edit permissions
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Account ID (found in Cloudflare dashboard sidebar)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# =============================================================================
# Discord - Alerting
# =============================================================================
# Webhook URL for SOC alerts channel
# Create in: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/xxxxx

# =============================================================================
# Email - Alerting (Optional)
# =============================================================================
# SMTP settings for email alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL=soc-alerts@yourdomain.com

# =============================================================================
# MaxMind GeoIP (Optional - for local GeoIP enrichment)
# =============================================================================
# License key from https://www.maxmind.com/en/my_license_key
# Free GeoLite2 databases available
MAXMIND_LICENSE_KEY=your_maxmind_license_key_here
