# SOC Automation Environment Variables
# Copy to .env and fill in your values

# OpenSearch Connection
OPENSEARCH_HOST=100.110.112.98
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASS=your-opensearch-password

# AbuseIPDB API (free tier: 1000 checks/day)
# Get your key at: https://www.abuseipdb.com/account/api
ABUSEIPDB_KEY=your-abuseipdb-api-key

# Cloudflare API (for auto-blocking)
# Create token at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Account > Account Firewall Access Rules > Edit
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# Discord Webhook (for alerts and digests)
# Create in Discord: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK=https://discord.com/api/webhooks/your-webhook-url

# Timezone for watch schedules
TZ=America/New_York

# Blocking threshold (only block IPs with score >= this value)
BLOCK_THRESHOLD=90
